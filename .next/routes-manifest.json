{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/admin/clusters/[id]",
      "regex": "^/api/admin/clusters/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/admin/clusters/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/admin/drafts/[id]",
      "regex": "^/api/admin/drafts/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/admin/drafts/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/admin/prompts/[id]",
      "regex": "^/api/admin/prompts/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/admin/prompts/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/daily-current-affairs/[date]",
      "regex": "^/daily\\-current\\-affairs/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPdate": "nxtPdate"
      },
      "namedRegex": "^/daily\\-current\\-affairs/(?<nxtPdate>[^/]+?)(?:/)?$"
    },
    {
      "page": "/daily-mcqs/[date]",
      "regex": "^/daily\\-mcqs/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPdate": "nxtPdate"
      },
      "namedRegex": "^/daily\\-mcqs/(?<nxtPdate>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/admin",
      "regex": "^/admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin(?:/)?$"
    },
    {
      "page": "/auth",
      "regex": "^/auth(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/auth(?:/)?$"
    },
    {
      "page": "/daily-current-affairs",
      "regex": "^/daily\\-current\\-affairs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/daily\\-current\\-affairs(?:/)?$"
    },
    {
      "page": "/daily-mcqs",
      "regex": "^/daily\\-mcqs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/daily\\-mcqs(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}